{
  "name": "tanstartercn",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vp dev",
    "build": "pnpm registry:build && pnpm static:build && vp build",
    "preview": "vp preview",
    "deploy": "pnpm build && wrangler deploy",
    "cf-typegen": "wrangler types",
    "typecheck": "tsc --noEmit",
    "registry:build": "shadcn build registry.json --output ./public/r",
    "static:build": "node scripts/generate-static-assets.mjs",
    "postinstall": "fumadocs-mdx",
    "check": "vp check",
    "fix": "vp check --fix",
    "prepare": "vp config",
    "deps": "vpx taze@latest -Ilwr --maturity-period 3 --exclude ts-morph",
    "deps:major": "vpx taze@latest major -Ilwr --maturity-period 3 --exclude ts-morph",
    "tanstack": "pnpm dlx @tanstack/cli@latest",
    "skills": "pnpm dlx skills@latest",
    "intent": "pnpm dlx @tanstack/intent@latest"
  },
  "dependencies": {
    "@bprogress/react": "catalog:",
    "@fontsource-variable/geist": "catalog:",
    "@fontsource-variable/geist-mono": "catalog:",
    "@tailwindcss/postcss": "catalog:",
    "@tanstack/react-router": "catalog:",
    "@tanstack/react-start": "catalog:",
    "class-variance-authority": "catalog:",
    "clsx": "catalog:",
    "cmdk": "catalog:",
    "fumadocs-core": "catalog:",
    "jotai": "catalog:",
    "lru-cache": "catalog:",
    "lucide-react": "catalog:",
    "motion": "catalog:",
    "next-themes": "catalog:",
    "postcss": "catalog:",
    "radix-ui": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-hotkeys-hook": "catalog:",
    "shiki": "catalog:",
    "sonner": "catalog:",
    "tailwind-merge": "catalog:",
    "takumi-js": "^1.8.7",
    "vaul": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.42.1",
    "@tailwindcss/postcss": "catalog:",
    "@tanstack/router-plugin": "catalog:",
    "@types/mdx": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "fumadocs-mdx": "catalog:",
    "rehype-pretty-code": "catalog:",
    "shadcn": "catalog:",
    "tailwindcss": "catalog:",
    "tw-animate-css": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "wrangler": "^4.103.0"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.8.0",
      "onFail": "download"
    }
  }
}
